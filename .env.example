# 本地开发环境变量模板。
# 使用方式：复制为 .env，然后填入自己的真实密钥。

MEYO_LANG=zh
MEYO_ENCRYPT_KEY=your_secret_key

# 硅基流动 API Key，配置文件中的 ${env:SILICONFLOW_API_KEY} 会读取这里。
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key

# 可选：不配置时默认使用 https://api.siliconflow.cn/v1
# SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1

# DeepSeek API Key，对应 provider = "proxy/deepseek"。
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# OpenAI API Key，对应 provider = "proxy/openai"。
OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_API_BASE=https://api.openai.com/v1

# 通义千问 / Qwen API Key，对应 provider = "proxy/tongyi"。
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
# DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# 火山方舟 API Key，对应 provider = "proxy/volcengine"。
ARK_API_KEY=sk-your-volcengine-ark-api-key
# ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL_NAME=deepseek-v3-241226

# 下面这些是已迁移但默认不启用的其它 LLM provider，需要对应配置文件时再填写。
# AIMLAPI_API_KEY=sk-your-aimlapi-api-key
# BAICHUAN_API_KEY=sk-your-baichuan-api-key
# BURNCLOUD_API_KEY=sk-your-burncloud-api-key
# ANTHROPIC_API_KEY=sk-your-anthropic-api-key
# GEMINI_PROXY_API_KEY=sk-your-gemini-api-key
# GITEE_API_KEY=sk-your-gitee-api-key
# INFINIAI_API_KEY=sk-your-infiniai-api-key
# MINIMAX_API_KEY=sk-your-minimax-api-key
# MOONSHOT_API_KEY=sk-your-moonshot-api-key
# XUNFEI_SPARK_API_KEY=sk-your-spark-api-key
# WEN_XIN_API_KEY=your-wenxin-api-key
# WEN_XIN_API_SECRET=your-wenxin-api-secret
# YI_API_KEY=sk-your-yi-api-key
# ZHIPUAI_API_KEY=sk-your-zhipu-api-key
